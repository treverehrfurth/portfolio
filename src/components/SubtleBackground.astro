---
import TwinklingStars from "@components/TwinklingStars.astro"
import MeteorShower from "@components/MeteorShower.astro"
---

<div
  class="absolute inset-x-0 top-0 h-[50vh] pointer-events-none overflow-hidden"
  style="mask-image: linear-gradient(to bottom, black 20%, transparent 90%); -webkit-mask-image: linear-gradient(to bottom, black 20%, transparent 90%);"
>
  <!-- Light Mode: dark particles -->
  <div class="absolute inset-0 block dark:hidden opacity-75">
    <div id="pg-particles1" class="absolute inset-0"></div>
    <div id="pg-particles2" class="absolute inset-0"></div>
    <div id="pg-particles3" class="absolute inset-0"></div>
  </div>

  <!-- Dark Mode: white stars -->
  <div class="absolute inset-0 hidden dark:block opacity-75">
    <div id="pg-stars1" class="absolute inset-0"></div>
    <div id="pg-stars2" class="absolute inset-0"></div>
    <div id="pg-stars3" class="absolute inset-0"></div>
  </div>

  <!-- Twinkling stars + meteors -->
  <div id="galaxy" class="absolute inset-0">
    <TwinklingStars />
    <MeteorShower />
  </div>
</div>

<script is:inline>
  function pgGetRandom(max) {
    return Math.floor(Math.random() * max);
  }

  function pgGenerateParticles(n) {
    let value = `${pgGetRandom(2560)}px ${pgGetRandom(2560)}px #000`;
    for (let i = 2; i <= n; i++) {
      value += `, ${pgGetRandom(2560)}px ${pgGetRandom(2560)}px #000`;
    }
    return value;
  }

  function pgGenerateStars(n) {
    let value = `${pgGetRandom(2560)}px ${pgGetRandom(2560)}px #fff`;
    for (let i = 2; i <= n; i++) {
      value += `, ${pgGetRandom(2560)}px ${pgGetRandom(2560)}px #fff`;
    }
    return value;
  }

  function initPageBG() {
    const p1 = document.getElementById('pg-particles1');
    const p2 = document.getElementById('pg-particles2');
    const p3 = document.getElementById('pg-particles3');
    if (p1) p1.style.cssText = `width:1px;height:1px;border-radius:50%;box-shadow:${pgGenerateParticles(300)};animation:animateParticle 50s linear infinite;`;
    if (p2) p2.style.cssText = `width:1.5px;height:1.5px;border-radius:50%;box-shadow:${pgGenerateParticles(150)};animation:animateParticle 100s linear infinite;`;
    if (p3) p3.style.cssText = `width:2px;height:2px;border-radius:50%;box-shadow:${pgGenerateParticles(75)};animation:animateParticle 150s linear infinite;`;

    const s1 = document.getElementById('pg-stars1');
    const s2 = document.getElementById('pg-stars2');
    const s3 = document.getElementById('pg-stars3');
    if (s1) s1.style.cssText = `width:1px;height:1px;border-radius:50%;box-shadow:${pgGenerateStars(300)};`;
    if (s2) s2.style.cssText = `width:1.5px;height:1.5px;border-radius:50%;box-shadow:${pgGenerateStars(150)};`;
    if (s3) s3.style.cssText = `width:2px;height:2px;border-radius:50%;box-shadow:${pgGenerateStars(75)};`;
  }

  document.addEventListener('astro:after-swap', initPageBG);
  initPageBG();
</script>
