---
import { getCollection } from "astro:content"
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { ACCOMPLISHMENTS } from "@consts"
import SubtleBackground from "@components/SubtleBackground.astro"
import AccomplishmentsFilter from "@components/AccomplishmentsFilter"

const collection = await getCollection("accomplishments", ({ data }) => !data.draft)

collection.sort((a, b) => b.data.date.getTime() - a.data.date.getTime())

const items = await Promise.all(
  collection.map(async (item) => {
    const { Content } = await item.render()
    return { ...item, Content }
  })
)

const filterItems = items.map((item) => ({
  id: item.slug,
  title: item.data.title,
  summary: item.data.summary,
  tags: item.data.tags ?? [],
}))

const allTags = Array.from(
  new Set(filterItems.flatMap((i) => i.tags))
).sort()
---

<PageLayout title={ACCOMPLISHMENTS.TITLE} description={ACCOMPLISHMENTS.DESCRIPTION}>
  <SubtleBackground />
  <TopLayout>
    <div class="animate">
      <h1 class="text-3xl font-semibold text-black dark:text-white mt-2">
        {ACCOMPLISHMENTS.TITLE}
      </h1>
      <div class="mt-1">
        {ACCOMPLISHMENTS.DESCRIPTION}
      </div>
    </div>
  </TopLayout>
  <BottomLayout>
    <div class="animate mb-6">
      <AccomplishmentsFilter client:load items={filterItems} tags={allTags} />
    </div>
    <ul>
      {items.map((entry) => (
        <li
          data-accomplishment-id={entry.slug}
          class="animate border-b border-black/10 dark:border-white/25 mt-4 py-8 first-of-type:mt-0 first-of-type:pt-0 last-of-type:border-none"
        >
          <div class="text-sm uppercase mb-4">
            {entry.data.date.toLocaleDateString("en-US", { month: "short", year: "numeric" })}
          </div>
          <div class="text-black dark:text-white font-semibold">
            {entry.data.title}
          </div>
          <div class="text-sm opacity-75 mt-1">
            {entry.data.summary}
          </div>
          {entry.data.tags && (
            <div class="flex flex-wrap gap-2 mt-2">
              {entry.data.tags.map((tag: string) => (
                <span class="text-xs border border-black/15 dark:border-white/20 rounded px-2 py-0.5">
                  {tag}
                </span>
              ))}
            </div>
          )}
          <article class="prose dark:prose-invert mt-4">
            <entry.Content />
          </article>
        </li>
      ))}
    </ul>
  </BottomLayout>
</PageLayout>
