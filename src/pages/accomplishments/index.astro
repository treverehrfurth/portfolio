---
import PageLayout from "@layouts/PageLayout.astro"
import TopLayout from "@layouts/TopLayout.astro"
import BottomLayout from "@layouts/BottomLayout.astro"
import { ACCOMPLISHMENTS } from "@consts"

const certifications = [
  { name: "Informatica Certified", issuer: "Informatica" },
  { name: "Matillion Certified", issuer: "Matillion" },
  { name: "Snowflake Certified", issuer: "Snowflake" },
]

const education = [
  {
    institution: "St. Norbert College",
    location: "De Pere, WI",
    degree: "Master of Business Administration",
    dateStart: "Sep 2019",
    dateEnd: "May 2022",
    notes: "3.9/4.0 GPA",
  },
  {
    institution: "University of Wisconsin – Green Bay",
    location: "Green Bay, WI",
    degree: "BS, Computer Science and German",
    dateStart: "Sep 2013",
    dateEnd: "May 2017",
    notes: "Magna Cum Laude · 3.8/4.0 GPA",
  },
]
---

<PageLayout title={ACCOMPLISHMENTS.TITLE} description={ACCOMPLISHMENTS.DESCRIPTION}>
  <TopLayout>
    <div class="animate page-heading">
      {ACCOMPLISHMENTS.TITLE}
    </div>
  </TopLayout>
  <BottomLayout>

    <!-- Education -->
    <div class="animate font-semibold text-black dark:text-white mb-4">
      Education
    </div>
    <ul>
      {education.map((entry) => (
        <li class="animate border-b border-black/10 dark:border-white/25 mt-4 py-8 first-of-type:mt-0 first-of-type:pt-0 last-of-type:border-none">
          <div class="text-sm uppercase mb-4">
            {entry.dateStart} - {entry.dateEnd}
          </div>
          <div class="text-black dark:text-white font-semibold">
            {entry.institution}
          </div>
          <div class="text-sm font-semibold">
            {entry.degree}
          </div>
          <div class="text-sm opacity-75 mt-1">
            {entry.location}
          </div>
          <div class="prose dark:prose-invert mt-2 text-sm">
            {entry.notes}
          </div>
        </li>
      ))}
    </ul>

    <!-- Certifications -->
    <div class="animate font-semibold text-black dark:text-white mt-12 mb-4">
      Certifications
    </div>
    <ul>
      {certifications.map((cert) => (
        <li class="animate border-b border-black/10 dark:border-white/25 py-6 first-of-type:pt-0 last-of-type:border-none">
          <div class="text-black dark:text-white font-semibold">
            {cert.name}
          </div>
          <div class="text-sm opacity-75">
            {cert.issuer}
          </div>
        </li>
      ))}
    </ul>

  </BottomLayout>
</PageLayout>
